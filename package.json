{
  "name": "teachercollab",
  "version": "0.1.0",
  "private": true,
  "overrides": {},
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run lint && next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "postinstall": "prisma generate --no-engine",
    "fix-postgres-sequence": "npx ts-node --project tsconfig.scripts.json prisma/scripts/fix-postgres-sequence.ts",
    "export-db": "ts-node prisma/scripts/export-to-csv.ts",
    "import-db": "npx ts-node --project tsconfig.scripts.json prisma/scripts/import-all.ts",
    "import-db-except-chat-related": "npx ts-node --project tsconfig.scripts.json prisma/scripts/import-all-except-chat-related.ts",
    "import-db:users": "npx ts-node prisma/scripts/import-from-csv.ts User ./prisma/exports/export-User.csv",
    "import-db:personas": "npx ts-node prisma/scripts/import-from-csv.ts Persona ./prisma/exports/export-Persona.csv",
    "import-db:settings": "npx ts-node prisma/scripts/import-from-csv.ts Settings ./prisma/exports/export-Settings.csv",
    "import-db:switches": "npx ts-node prisma/scripts/import-from-csv.ts SettingsSwitch ./prisma/exports/export-SettingsSwitch.csv",
    "import-db:problems": "npx ts-node prisma/scripts/import-from-csv.ts Problem ./prisma/exports/export-Problem.csv",
    "import-db:transcripts": "npx ts-node prisma/scripts/import-from-csv.ts Transcript ./prisma/exports/export-Transcript.csv",
    "import-db:chat-templates": "npx ts-node prisma/scripts/import-from-csv.ts ChatTemplate ./prisma/exports/export-ChatTemplate.csv",
    "import-db:template-problems": "npx ts-node prisma/scripts/import-from-csv.ts ChatTemplateProblem ./prisma/exports/export-ChatTemplateProblem.csv",
    "import-db:chats": "npx ts-node prisma/scripts/import-from-csv.ts Chat ./prisma/exports/export-Chat.csv",
    "import-db:learning-sequences": "npx ts-node prisma/scripts/import-from-csv.ts LearningSequence ./prisma/exports/export-LearningSequence.csv",
    "import-db:messages": "npx ts-node prisma/scripts/import-from-csv.ts Message ./prisma/exports/export-Message.csv"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.1",
    "@elevenlabs/elevenlabs-js": "^2.32.0",
    "@heroui/checkbox": "^2.3.29",
    "@heroui/react": "^2.8.7",
    "@heroui/system": "^2.4.25",
    "@heroui/theme": "^2.4.25",
    "@prisma/client": "^6.18.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@tanstack/react-query": "^5.90.20",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "core-js": "^3.45.1",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.2.3",
    "eventsource-parser": "^3.0.6",
    "framer-motion": "^12.29.0",
    "heroui-cli": "^1.2.3",
    "immer": "^10.2.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.4",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.12",
    "openai": "^6.16.0",
    "p-queue": "^9.1.0",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-speech-recognition": "^4.0.1",
    "react-syntax-highlighter": "^16.1.0",
    "react-tabs": "^6.1.0",
    "react-textarea-autosize": "^8.5.9",
    "react-toastify": "^11.0.5",
    "regenerator-runtime": "^0.14.1",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.0.10",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.2",
    "@types/react-speech-recognition": "^3.9.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-textarea-autosize": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
